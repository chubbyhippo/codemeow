        "command": "codemeow.editRc",
        "title": "Edit .codemeowrc",
        "category": "codemeow"
      },
      {
        "command": "codemeow.cheatsheet",
        "title": "Meow Cheatsheet",
        "category": "codemeow"
      },
      {
        "command": "codemeow.commandIds",
        "title": "Find Command Id",
        "category": "codemeow"
      },
      {
        "command": "codemeow.windmoveLeft",
        "title": "Windmove Left",
        "category": "codemeow"
      },
      {
        "command": "codemeow.windmoveRight",
        "title": "Windmove Right",
        "category": "codemeow"
      },
      {
        "command": "codemeow.windmoveUp",
        "title": "Windmove Up",
        "category": "codemeow"
      },
      {
        "command": "codemeow.windmoveDown",
        "title": "Windmove Down",
        "category": "codemeow"
      }
