        "when": "listFocus && !inputFocus && !treestickyScrollFocused && !treeFindOpen && !notebookEditorFocused && codemeow.tree.doubleQuote"
      },
      {
        "key": ",",
        "command": "codemeow.tree",
        "args": ",",
        "when": "listFocus && !inputFocus && !treestickyScrollFocused && !treeFindOpen && !notebookEditorFocused && codemeow.tree.comma"
      },
      {
        "key": "shift+,",
        "command": "codemeow.tree",
        "args": "<",
        "when": "listFocus && !inputFocus && !treestickyScrollFocused && !treeFindOpen && !notebookEditorFocused && codemeow.tree.less"
      },
      {
        "key": ".",
        "command": "codemeow.tree",
        "args": ".",
        "when": "listFocus && !inputFocus && !treestickyScrollFocused && !treeFindOpen && !notebookEditorFocused && codemeow.tree.period"
      },
      {
        "key": "shift+.",
        "command": "codemeow.tree",
        "args": ">",
        "when": "listFocus && !inputFocus && !treestickyScrollFocused && !treeFindOpen && !notebookEditorFocused && codemeow.tree.greater"
      },
      {
        "key": "/",
        "command": "codemeow.tree",
        "args": "/",
        "when": "listFocus && !inputFocus && !treestickyScrollFocused && !treeFindOpen && !notebookEditorFocused && codemeow.tree.slash"
      },
      {
        "key": "shift+/",
        "command": "codemeow.tree",
        "args": "?",
        "when": "listFocus && !inputFocus && !treestickyScrollFocused && !treeFindOpen && !notebookEditorFocused && codemeow.tree.question"
      }
    ]
  },
